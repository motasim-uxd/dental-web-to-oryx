# Copy into Vercel: Project → Settings → Environment Variables (Production + Preview).

# Required for GHL webhooks: same value as custom header x-api-key in GHL.
GHL_WEBHOOK_SECRET=

# Optional: public URL of your Whisper HTTP API (Vercel cannot reach localhost).
# If unset, STT defaults to http://127.0.0.1:9000/inference (local dev only).
WHISPER_SERVER_URL=
