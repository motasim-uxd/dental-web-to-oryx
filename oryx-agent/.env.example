# Copy into Vercel: Project → Settings → Environment Variables (Production + Preview).

# Required for GHL webhooks: same value as custom header x-api-key in GHL.
GHL_WEBHOOK_SECRET=

# Default Oryx realm when the GHL payload does not include `realm` / `oryx_realm`.
GHL_ORYX_REALM=smilesquadpd

# If true, allow missing/invalid phoneNumber and substitute a placeholder for Oryx.
# Useful for early testing while you wire contact phone mapping in GHL.
GHL_ALLOW_MISSING_PHONE=false

# If true, missing appointment date/time can be parsed from the call transcript (chrono).
# Still requires extracted contact fields (name, email, DOB, phone) for safety.
GHL_VOICE_PARSE_TRANSCRIPT=false

# Optional: public URL of your Whisper HTTP API (Vercel cannot reach localhost).
# If unset, STT defaults to http://127.0.0.1:9000/inference (local dev only).
WHISPER_SERVER_URL=
